{
  "version": 2,
  "installCommand": "pip install -r requirements-vercel.txt",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ],
  "functions": {
    "api/index.py": {
      "memory": 1024,
      "maxDuration": 60,
      "includeFiles": "data/leasepulse.db"
    },
    "api/main.py": {
      "memory": 1024,
      "maxDuration": 60,
      "includeFiles": "data/leasepulse.db"
    }
  }
}
